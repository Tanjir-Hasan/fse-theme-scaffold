{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "useRootPaddingAwareAlignments": true,
    "appearanceTools": true,
    "color": {
      "palette": [
        { "name": "Primary", "color": "#2563EB", "slug": "primary" },
        { "name": "Primary Dark", "color": "#1E40AF", "slug": "primary-dark" },
        { "name": "Heading", "color": "#111827", "slug": "heading" },
        { "name": "Body", "color": "#4B5563", "slug": "body" },
        { "name": "Background", "color": "#FFFFFF", "slug": "background" },
        { "name": "Surface", "color": "#F3F4F6", "slug": "surface" },
        { "name": "Border", "color": "#E5E7EB", "slug": "border" },
        { "name": "Transparent", "color": "transparent", "slug": "transparent" },
        { "name": "Current Color", "color": "currentColor", "slug": "currentcolor" }
      ],
      "gradients": [
        { "slug": "primary", "gradient": "linear-gradient(135deg, #3B82F6 0%, #1D4ED8 100%)", "name": "Primary" }
      ]
    },
    "spacing": {
      "units": [ "%", "px", "em", "rem", "vh", "vw" ],
      "spacingSizes": [
        { "name": "XXX Small", "slug": "xxx-small", "size": "4px" },
        { "name": "XX Small", "slug": "xx-small", "size": "8px" },
        { "name": "X Small", "slug": "x-small", "size": "12px" },
        { "name": "Small", "slug": "small", "size": "16px" },
        { "name": "Medium", "slug": "medium", "size": "24px" },
        { "name": "Large", "slug": "large", "size": "32px" },
        { "name": "X Large", "slug": "x-large", "size": "48px" },
        { "name": "XX Large", "slug": "xx-large", "size": "64px" },
        { "name": "XXX Large", "slug": "xxx-large", "size": "96px" },
        { "name": "XXXX Large", "slug": "xxxx-large", "size": "120px" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
          "name": "System Default",
          "slug": "system"
        }
      ],
      "fontSizes": [
        { "name": "X Small", "size": "clamp(12px, 1.4vw, 14px)", "slug": "x-small", "fluid": { "min": "12px", "max": "14px" } },
        { "name": "Small", "size": "clamp(14px, 1.6vw, 16px)", "slug": "small", "fluid": { "min": "14px", "max": "16px" } },
        { "name": "Medium", "size": "clamp(16px, 1.8vw, 18px)", "slug": "medium", "fluid": { "min": "16px", "max": "18px" } },
        { "name": "Large", "size": "clamp(18px, 2vw, 20px)", "slug": "large", "fluid": { "min": "18px", "max": "20px" } },
        { "name": "X Large", "size": "clamp(20px, 2.4vw, 24px)", "slug": "x-large", "fluid": { "min": "20px", "max": "24px" } },
        { "name": "XX Large", "size": "clamp(26px, 3vw, 32px)", "slug": "xx-large", "fluid": { "min": "26px", "max": "32px" } },
        { "name": "XXX Large", "size": "clamp(32px, 3.6vw, 40px)", "slug": "xxx-large", "fluid": { "min": "32px", "max": "40px" } },
        { "name": "XXXX Large", "size": "clamp(38px, 5vw, 48px)", "slug": "xxxx-large", "fluid": { "min": "38px", "max": "48px" } }
      ]
    },
    "layout": {
      "contentSize": "768px",
      "wideSize": "1200px"
    },
    "custom": {
      "fontWeight": {
        "regular": 400,
        "medium": 500,
        "semiBold": 600,
        "bold": 700
      },
      "lineHeight": {
        "initial": 1,
        "xxSmall": 1.2,
        "xSmall": 1.3,
        "small": 1.4,
        "medium": 1.45,
        "large": 1.6
      },
      "borderRadius": {
        "sm": "8px",
        "md": "16px",
        "pill": "9999px"
      },
      "font-family": {
        "heading": "var(--wp--preset--font-family--system)",
        "body": "var(--wp--preset--font-family--system)"
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--body)"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--small)"
    },
    "typography": {
      "fontSize": "var(--wp--preset--font-size--medium)",
      "fontFamily": "var(--wp--custom--font-family--body)",
      "fontWeight": "var(--wp--custom--font-weight--regular)",
      "lineHeight": "var(--wp--custom--line-height--large)"
    },
    "elements": {
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" },
        ":hover": { "color": { "text": "var(--wp--preset--color--primary-dark)" } }
      },
      "heading": {
        "color": { "text": "var(--wp--preset--color--heading)" },
        "typography": {
          "fontFamily": "var(--wp--custom--font-family--heading)",
          "fontWeight": "var(--wp--custom--font-weight--semiBold)"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--currentcolor)"
        },
        "border": {
          "radius": "var(--wp--custom--border-radius--pill)"
        },
        ":hover": {
          "color": { "background": "var(--wp--preset--color--primary-dark)" }
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontFamily": "var(--wp--custom--font-family--heading)",
          "fontWeight": "var(--wp--custom--font-weight--medium)"
        }
      },
      "core/separator": {
        "color": { "background": "var(--wp--preset--color--border)" }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
